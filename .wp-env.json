{
    "plugins": [
        "./.wp-env-sources/etch",
        "./.wp-env-sources/etch-builders-test-bootstrap"
    ],
    "themes": [
        "./.wp-env-sources/etch-theme"
    ],
    "mappings": {
        "wp-content/etch-builders-tests": "."
    },
    "phpVersion": "8.2",
    "port": 8890,
    "testsPort": 8891,
    "config": {
        "WP_DEBUG": true,
        "WP_DEBUG_LOG": true,
        "SCRIPT_DEBUG": true,
        "WP_ENVIRONMENT_TYPE": "local",
        "ETCH_BUILDERS_WP_TESTS": true
    }
}

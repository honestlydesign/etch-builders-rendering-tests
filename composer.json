{
    "name": "honestlydesign/etch-builders-wp-tests",
    "description": "WP rendering tests for honestlydesign/etch-builders against the real Etch runtime.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "honestlydesign/etch-builders": "^1.1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "doctrine/instantiator": "<2.0.5 || ^3.0"
    },
    "autoload-dev": {
        "psr-4": {
            "HonestlyDesign\\EtchBuildersWpTests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false
    },
    "minimum-stability": "stable"
}
